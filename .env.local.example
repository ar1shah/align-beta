# Align — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# ─── Supabase (required) ────────────────────────────────────────────────────
# Find these in your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — used ONLY by the seed:quiz script (server-side, never exposed to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Email (optional, required for assignment notifications) ─────────────────
# Sign up at https://resend.com and create an API key
RESEND_API_KEY=re_your_api_key_here

# ─── App URL ─────────────────────────────────────────────────────────────────
# Used to generate absolute URLs in emails. Defaults to localhost in development.
NEXT_PUBLIC_APP_URL=http://localhost:3000
